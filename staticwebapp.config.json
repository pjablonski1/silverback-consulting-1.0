{
  "routes": [
    {
      "route": "/crm.html",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/crm.js",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/crm.css",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/client-portal.html",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/api/*",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    }
  ],
  "responseOverrides": {
    "403": {
      "rewrite": "/403.html",
      "statusCode": 403
    },
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains; preload",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
    "Content-Security-Policy": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; navigate-to 'self' mailto:;"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".webmanifest": "application/manifest+json"
  }
}
